{
  "manifest_version": 3,
  "name": "LI Outreach Automation",
  "version": "1.0.0",
  "description": "LinkedIn automation companion — connects your browser to LI Outreach backend.",

  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "notifications",
    "webRequest",
    "cookies"
  ],

  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.railway.app/*",
    "http://localhost:3001/*",
    "https://www.bing.com/*",
    "https://www.google.com/*",
    "https://html.duckduckgo.com/*",
    "https://duckduckgo.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "LI Outreach"
  }
}
