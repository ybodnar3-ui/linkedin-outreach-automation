# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Authentication ───────────────────────────────────────────────────────────
APP_USERNAME=admin
APP_PASSWORD=your-secure-password-here
JWT_SECRET=your-random-secret-here

# ─── Logging ──────────────────────────────────────────────────────────────────
# Options: error | warn | info | debug
LOG_LEVEL=info

# ─── AI Icebreaker (optional) ─────────────────────────────────────────────────
# Provide at least one key to use the {icebreaker} template variable.
# OpenAI is tried first; Anthropic is the fallback.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email Discovery (optional) ───────────────────────────────────────────────
HUNTER_API_KEY=
APOLLO_API_KEY=

# ─── Proxycurl (optional) ────────────────────────────────────────────────────
# Replaces Playwright DOM scraping with API — more reliable, includes email.
# Sign up at https://nubela.co/proxycurl · ~$0.01/profile
# PROXYCURL_API_KEY=
#
# Note: stored in DB via Settings page, not required in .env.

# ─── CRM Integrations (optional) ─────────────────────────────────────────────
# HubSpot: create a Private App in Settings → Integrations → Private Apps
# Grant "CRM: contacts" scope (read + write).
# HUBSPOT_API_KEY=pat-na1-...
#
# Pipedrive: find your token in Settings → Personal preferences → API
# PIPEDRIVE_API_TOKEN=
# PIPEDRIVE_DOMAIN=yourcompany   # e.g. "yourcompany" from yourcompany.pipedrive.com
#
# Note: these are stored in the DB via the Settings page, not required in .env.

# ─── Notes ────────────────────────────────────────────────────────────────────
# Most settings (SMTP, proxy, working hours, account name) are stored in the
# SQLite database via the Settings page — no .env needed for those.
#
# Copy this file to .env and fill in the values you need:
#   cp .env.example .env
#
# .env is in .gitignore and will never be committed.
