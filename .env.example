# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Logging ──────────────────────────────────────────────────────────────────
# Options: error | warn | info | debug
LOG_LEVEL=info

# ─── AI Icebreaker (optional) ─────────────────────────────────────────────────
# Provide at least one key to use the {icebreaker} template variable.
# OpenAI is tried first; Anthropic is the fallback.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email Discovery (optional) ───────────────────────────────────────────────
HUNTER_API_KEY=
APOLLO_API_KEY=

# ─── Notes ────────────────────────────────────────────────────────────────────
# Most settings (SMTP, proxy, working hours, account name) are stored in the
# SQLite database via the Settings page — no .env needed for those.
#
# Copy this file to .env and fill in the values you need:
#   cp .env.example .env
#
# .env is in .gitignore and will never be committed.
